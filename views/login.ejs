<!DOCTYPE html>
<html>
<head>
  <title>Nexora Login</title>
</head>
<body style="background:#0b0f19;color:white;font-family:Arial;text-align:center;padding-top:80px;">

  <h1>Nexora Login</h1>

  <form method="POST" action="/login">
    <input name="email" placeholder="Email" style="padding:10px;width:200px;"><br><br>
    <input name="password" type="password" placeholder="Password" style="padding:10px;width:200px;"><br><br>
    <button style="padding:10px 20px;">Login</button>
  </form>

  <p>
    <a href="/register" style="color:#00ffcc;">Create account</a>
  </p>

</body>
</html>
